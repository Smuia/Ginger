# ──────────────────────────────────────────────────────────────────────────────
# blueprawn_ai_sim — Environment Configuration Example
# ──────────────────────────────────────────────────────────────────────────────

# Set to true + provide API key to enable real OpenAI transcription & responses.
# When false (or key is empty), the server returns simulated responses.
USE_LIVE_AI=false

# OpenAI API key (required only when USE_LIVE_AI=true)
OPENAI_API_KEY=your_openai_api_key_here

# Model overrides (defaults are fine for POC)
# WHISPER_MODEL=whisper-1
# GPT_MODEL=gpt-4o-mini
# GPT_MAX_TOKENS=150

# Debug mode (enables verbose logging)
DEBUG=true
